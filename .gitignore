.env
.env.*
!.env.example
!.env.template

# === WORKFLOW KIT START ===
# Workflow layer (selective tracking)
/ANTIGRAVITY.md
/AGENTS.md
/GEMINI.md
/CLAUDE.md
/.claude/

# Exclude duplicated engine/tool copies
/ai-workflow/scripts/
/ai-workflow/skills/
/ai-workflow/workflow_kit/
/ai-workflow/mcp_servers/
/ai-workflow/schemas/
/ai-workflow/templates/
/ai-workflow/examples/
/ai-workflow/global-snippets/
/ai-workflow/harnesses/
/ai-workflow/tests/

# Keep the data (memory) and core guides
!/ai-workflow/README.md
!/ai-workflow/WORKFLOW_INDEX.md
!/ai-workflow/core/
!/ai-workflow/memory/
# === WORKFLOW KIT END ===

.venv/
node_modules/
.next/
dist/
build/
*.log

# dev-up.sh / dev-down.sh runtime PID files
.pids/

# === DEV ENVIRONMENT (machine-specific, untracked) ===
# 컨테이너/오케스트레이션 자산은 작업 환경별 제약이 다르므로 git 추적에서 제외한다.
# git 에는 환경 구성 가이드(docs/setup/environment-setup.md) 만 둔다.
docker-compose.yml
docker-compose.*.yml
**/Dockerfile
**/Dockerfile.*
**/.dockerignore

# === EDITOR / OS NOISE ===
.DS_Store
**/.DS_Store
*.bak
*.swp
Thumbs.db
docs/LOCAL_MACHINE_ENV.md
